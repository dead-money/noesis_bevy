<Grid xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#FF1A1410">
    <Grid.Resources>
        <Style TargetType="Button" x:Key="SpinOnClick">
            <Setter Property="Background" Value="#FFB34B2E"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontFamily" Value="Fonts/#Bitter"/>
            <Setter Property="FontSize" Value="24"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <RotateTransform Angle="0"/>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <EventTrigger RoutedEvent="Button.Click">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation
                                Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                From="0" To="360" Duration="0:0:0.6"/>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Style.Triggers>
        </Style>
    </Grid.Resources>
    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
        <TextBlock Text="Click the button — it should spin once."
                   Foreground="#FFE0E2EA" FontFamily="Fonts/#Bitter" FontSize="20"
                   HorizontalAlignment="Center" Margin="0,0,0,24"/>
        <Button Content="Spin!" Style="{StaticResource SpinOnClick}"
                Width="180" Height="72" HorizontalAlignment="Center"/>
    </StackPanel>
</Grid>
