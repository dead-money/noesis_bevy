<Grid xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#FF101318">
    <Grid.Resources>
        <!-- Inline ControlTemplate so the Style actually paints a themed
             button (Border + ContentPresenter). Without this Noesis falls
             back to its magenta "no-Template" placeholder and the Background
             / IsMouseOver trigger are both invisible. -->
        <Style TargetType="Button" x:Key="HoverSwatch">
            <Setter Property="Background" Value="#FF2B6CD6"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#FF8CB0FF"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="FontFamily" Value="Fonts/#Bitter"/>
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FFFF8A3C"/>
                    <Setter Property="BorderBrush" Value="#FFFFE2AE"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Grid.Resources>
    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
        <TextBlock Text="Hover the button — it should turn orange."
                   Foreground="#FFE0E2EA" FontFamily="Fonts/#Bitter" FontSize="20"
                   HorizontalAlignment="Center" Margin="0,0,0,24"/>
        <Button Content="Hover Me" Style="{StaticResource HoverSwatch}"
                Width="220" Height="64" HorizontalAlignment="Center"/>
    </StackPanel>
</Grid>
