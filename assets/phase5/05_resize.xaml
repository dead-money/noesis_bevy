<Grid xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#FF0C1A18">
    <!-- Percentage rows + corner anchors. Resizing the window should lay
         the quadrants out proportionally with the TextBlock centered. -->
    <Grid.RowDefinitions>
        <RowDefinition Height="*"/>
        <RowDefinition Height="*"/>
    </Grid.RowDefinitions>
    <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="*"/>
    </Grid.ColumnDefinitions>
    <Rectangle Grid.Row="0" Grid.Column="0" Fill="#FF234E46"/>
    <Rectangle Grid.Row="0" Grid.Column="1" Fill="#FF4F2D3A"/>
    <Rectangle Grid.Row="1" Grid.Column="0" Fill="#FF3E4A23"/>
    <Rectangle Grid.Row="1" Grid.Column="1" Fill="#FF2D3E61"/>
    <TextBlock Grid.Row="0" Grid.Column="0" Grid.RowSpan="2" Grid.ColumnSpan="2"
               Text="Resize the window — four quadrants should stay equal."
               Foreground="#FFF2F5FA" FontFamily="Fonts/#Bitter" FontSize="26"
               HorizontalAlignment="Center" VerticalAlignment="Center"/>
    <TextBlock Grid.Row="0" Grid.Column="0" Text="NW"
               Foreground="White" FontFamily="Fonts/#Bitter" FontSize="18"
               HorizontalAlignment="Left" VerticalAlignment="Top" Margin="12"/>
    <TextBlock Grid.Row="0" Grid.Column="1" Text="NE"
               Foreground="White" FontFamily="Fonts/#Bitter" FontSize="18"
               HorizontalAlignment="Right" VerticalAlignment="Top" Margin="12"/>
    <TextBlock Grid.Row="1" Grid.Column="0" Text="SW"
               Foreground="White" FontFamily="Fonts/#Bitter" FontSize="18"
               HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="12"/>
    <TextBlock Grid.Row="1" Grid.Column="1" Text="SE"
               Foreground="White" FontFamily="Fonts/#Bitter" FontSize="18"
               HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="12"/>
</Grid>
